# PostgreSQL connection string (local dev uses docker-compose).
# Managed Postgres that enforces TLS (e.g. AWS RDS, force_ssl) needs an SSL mode,
# otherwise the node-postgres driver connects without TLS and is rejected:
#   ...?schema=public&sslmode=no-verify
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/DBNAME?schema=public"

# JWT secrets — generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Google Books API key — https://console.cloud.google.com/ → enable "Books API" → Credentials
GOOGLE_BOOKS_API_KEY=

# AWS S3 — avatar/cover uploads (IAM user "sanctum-s3-uploader", least-privilege)
AWS_REGION=eu-central-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_PUBLIC_BASE_URL=https://<bucket>.s3.eu-central-1.amazonaws.com