// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ReadingState {
  WANT_TO_READ
  READING
  READ

  @@map("ShelfStatus")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  bio          String?
  avatarUrl    String?
  createdAt    DateTime @default(now())

  readingStatuses ReadingStatus[]
  reviews         Review[]
  refreshTokens   RefreshToken[]
  bookCovers      BookCover[]
  shelves         Shelf[]
}

model Book {
  id            String   @id @default(uuid())
  googleId      String   @unique
  title         String
  authors       String[]
  description   String?
  coverUrl      String?
  publishedYear Int?
  isbn          String?

  readingStatuses ReadingStatus[]
  reviews         Review[]
  bookCovers      BookCover[]
  shelfBooks      ShelfBook[]
}

model ReadingStatus {
  id      String       @id @default(uuid())
  status  ReadingState
  addedAt DateTime     @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookId String
  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@map("Shelf")
}

model Review {
  id        String   @id @default(uuid())
  rating    Int
  body      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookId String
  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
}

model BookCover {
  id        String   @id @default(uuid())
  coverUrl  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookId String
  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
}

model Shelf {
  id        String   @id @default(uuid())
  name      String
  color     String
  icon      String
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  items ShelfBook[]

  @@unique([userId, name])
  @@map("Bookshelf")
}

model ShelfBook {
  id      String   @id @default(uuid())
  addedAt DateTime @default(now())

  shelfId String
  shelf   Shelf  @relation(fields: [shelfId], references: [id], onDelete: Cascade)
  bookId  String
  book    Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([shelfId, bookId])
  @@map("BookshelfItem")
}

model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}
